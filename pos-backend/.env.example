# ── Server ─────────────────────────────────────────────────────────
PORT=3000

# ── Database (option A: single connection string, e.g. Render/Neon) ─
# DATABASE_URL=postgresql://user:password@host:5432/swiftpos

# ── Database (option B: local PostgreSQL) ──────────────────────────
DB_USER=postgres
DB_HOST=localhost
DB_NAME=swiftpos
DB_PASSWORD=your_postgres_password
DB_PORT=5432

# ── Auth ───────────────────────────────────────────────────────────
# Any long random string — used to sign JWT login tokens
JWT_SECRET=change_me_to_a_long_random_string

# ── Paystack (https://dashboard.paystack.com → Settings → API Keys) ─
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# ── CORS (optional) — extra allowed frontend origin in production ──
# FRONTEND_URL=https://your-frontend.example.com
